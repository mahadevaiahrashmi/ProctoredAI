# =============================================================================
# ProctoredAI — Environment Variables (TEMPLATE)
# =============================================================================
# Copy this file to `.env` and fill in real values:
#
#     cp .env.example .env
#
# `.env` is git-ignored; this `.env.example` is committed as the reference.
# The dev entrypoint (src/ai/dev.ts) loads `.env` via dotenv, and Next.js loads
# it automatically. Restart the dev server after changing any value.
# =============================================================================

# -----------------------------------------------------------------------------
# AI PROVIDER SELECTION
# -----------------------------------------------------------------------------
# Which AI backend powers exam generation, proctoring, grading, the tutor, and
# TTS. Selected once at startup in src/ai/genkit.ts. One of:
#
#   googleai     Google Gemini (DEFAULT). Multimodal text + vision + TTS.
#                The only provider that supports the spoken tutor (TTS).
#                Needs GEMINI_API_KEY (or GOOGLE_API_KEY) below.
#   ollama       Local models via Ollama — no API key, runs on your machine.
#                Free and private. No TTS (tutor falls back to text). Webcam
#                proctoring only runs if you set OLLAMA_VISION_MODEL.
#   openrouter   OpenAI-compatible gateway with some free models. Still needs a
#                (free) OPENROUTER_API_KEY. No TTS.
#
# Leave unset/blank to use the default (googleai). Anything unrecognized also
# falls back to googleai.
# AI_PROVIDER=googleai

# -----------------------------------------------------------------------------
# REQUIRED for AI_PROVIDER=googleai — Google Gemini API key
# -----------------------------------------------------------------------------
# Used by the Genkit Google AI plugin (@genkit-ai/google-genai) for every AI
# feature: exam generation, webcam violation detection, grading, the AI tutor,
# and TTS. Get a free key from Google AI Studio:
#   https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Alternative key name (the plugin also accepts GOOGLE_API_KEY). Set ONE of
# GEMINI_API_KEY or this. Leave blank if you are using GEMINI_API_KEY above.
# GOOGLE_API_KEY=

# -----------------------------------------------------------------------------
# For AI_PROVIDER=ollama — local, keyless models (https://ollama.com)
# -----------------------------------------------------------------------------
# Install Ollama, then `ollama pull <model>` before running. No API key needed.
#
# NOTE: small local models (e.g. llama3.2 3B) reliably handle the chat tutor and
# plain text, but the structured exam-generation and grading flows can be
# unreliable on them — see TD-020 in docs/tech_debt.md. For full exam flows use a
# larger instruct model locally, or use googleai / openrouter.
#
# Text/chat model (default "llama3.2"):
# OLLAMA_MODEL=llama3.2
#
# Vision model for webcam proctoring. If UNSET, proctoring is DISABLED and the
# exam runs unproctored on Ollama. Set to a multimodal model you have pulled:
# OLLAMA_VISION_MODEL=llama3.2-vision
#
# Ollama server address (default http://localhost:11434):
# OLLAMA_SERVER_ADDRESS=http://localhost:11434

# -----------------------------------------------------------------------------
# For AI_PROVIDER=openrouter — OpenAI-compatible gateway (https://openrouter.ai)
# -----------------------------------------------------------------------------
# Free key (required even for free models): https://openrouter.ai/keys
# OPENROUTER_API_KEY=
#
# Model slug (default "meta-llama/llama-3.2-11b-vision-instruct:free"). The
# default is a free vision model so proctoring works; pick any OpenRouter model:
# OPENROUTER_MODEL=meta-llama/llama-3.2-11b-vision-instruct:free

# -----------------------------------------------------------------------------
# OPTIONAL — Genkit environment
# -----------------------------------------------------------------------------
# Set to "dev" to enable Genkit dev-time behavior/telemetry when running the
# Genkit developer UI (npm run genkit:dev). Not required for the Next.js app.
# GENKIT_ENV=dev
