# =============================================================================
# ProctoredAI — Environment Variables (TEMPLATE)
# =============================================================================
# Copy this file to `.env` and fill in real values:
#
#     cp .env.example .env
#
# `.env` is git-ignored; this `.env.example` is committed as the reference.
# The dev entrypoint (src/ai/dev.ts) loads `.env` via dotenv, and Next.js loads
# it automatically. Restart the dev server after changing any value.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED — Google Gemini API key
# -----------------------------------------------------------------------------
# Used by the Genkit Google AI plugin (@genkit-ai/googleai) for every AI feature:
# exam generation, webcam violation detection, grading, the AI tutor, and TTS.
# Get a free key from Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# OPTIONAL — Alternative key name
# -----------------------------------------------------------------------------
# The plugin also accepts GOOGLE_API_KEY. Set ONE of GEMINI_API_KEY or this.
# Leave blank if you are using GEMINI_API_KEY above.
# GOOGLE_API_KEY=

# -----------------------------------------------------------------------------
# OPTIONAL — Genkit environment
# -----------------------------------------------------------------------------
# Set to "dev" to enable Genkit dev-time behavior/telemetry when running the
# Genkit developer UI (npm run genkit:dev). Not required for the Next.js app.
# GENKIT_ENV=dev
